# ── Frontend (Vite) environment ──────────────────────────────────────────
# Base URL of the backend API.
#   Local:      http://localhost:5000/api
#   Production: https://campus-placement-portal-dl0o.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Google OAuth 2.0 Web client ID (must match the backend GOOGLE_CLIENT_ID).
# Add your frontend origin to "Authorized JavaScript origins" in Google Console.
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
