# ── MongoDB ──────────────────────────────────────────────────────────────
# Connection string from MongoDB Atlas (Database → Connect → Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/placement_db?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────────
# Any long random string (used to sign JWTs)
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth 2.0 Web client ID (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ── Email notifications (optional) ────────────────────────────────────────
# Gmail address + 16-char App Password (Google Account → Security → App passwords).
# If left blank, the portal still runs and simply skips sending emails.
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_16_char_gmail_app_password
